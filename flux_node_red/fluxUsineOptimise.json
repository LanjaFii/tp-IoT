    {
        "id": "5ab81432bfa539b4",
        "type": "function",
        "z": "73a689065fe1bb03",
        "name": "function 1",
        "func": "let temp = parseFloat(msg.payload);\n\n// Pour le debug, tu peux créer un autre msg pour la console\nmsg.alert = temp > 30 ? \"⚠️ ALERTE température: \" + temp : \"Température normale: \" + temp;\n\n// msg.payload reste le nombre pour la Gauge\nmsg.payload = temp;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
