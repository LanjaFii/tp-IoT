    {
        "id": "fccf044c543f43a5",
        "type": "function",
        "z": "73a689065fe1bb03",
        "name": "function 3",
        "func": "let data = msg.payload;\n\n// machine ID\nmsg.machine = msg.topic.split(\"/\")[1];\n\n// alertes\nlet alerts = [];\n\nif(data.temperature > 30) alerts.push(\"Température élevée\");\nif(data.humidity > 65) alerts.push(\"Humidité élevée\");\nif(data.vibration > 7) alerts.push(\"Vibration critique\");\nif(data.flamme) alerts.push(\"🔥 Flamme détectée !\");\nif(data.fumee) alerts.push(\"💨 Fumée détectée !\");\n\nmsg.alerts = alerts.length ? alerts.join(\", \") : \"OK\";\n\n// envoyer données directes\nmsg.temperature = data.temperature;\nmsg.humidity = data.humidity;\nmsg.vibration = data.vibration;\nmsg.flamme = data.flamme;\nmsg.fumee = data.fumee;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 360,
