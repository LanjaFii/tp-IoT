    {
        "id": "52383c63f8265fe2",
        "type": "ui-template",
        "z": "73a689065fe1bb03",
        "group": "612ff79d3253bdae",
        "page": "",
        "ui": "",
        "name": "Temperax",
        "order": 6,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div class=\"gauge-card\">\n    <div class=\"card-title\">Température Machine</div>\n\n    <div class=\"gauge-container\">\n      <div class=\"gauge\"></div>\n    </div>\n\n    <div class=\"status-box\" :class=\"{alert: currentTemp > 35}\">\n      <span class=\"status-dot\"></span>\n      {{ currentTemp > 35 ? \"Surchauffe\" : \"Normal\" }}\n    </div>\n  </div>\n</template>\n\n<script>\n  export default {\n    data() {\n        return {\n            chart: null,\n            currentTemp: 0\n        }\n    },\n\n    watch: {\n        msg: function(newMsg){\n\n            if(!newMsg) return;\n\n            if(newMsg.temperature !== undefined){\n\n                this.currentTemp = parseFloat(newMsg.temperature);\n\n                this.updateGauge();\n\n            }\n\n        }\n    },\n\n    methods: {\n\n        updateGauge(){\n\n            if(!this.chart) return;\n\n            let color = \"#00E396\"; // vert\n\n            if(this.currentTemp > 30) color = \"#FEB019\"; // orange\n            if(this.currentTemp > 35) color = \"#FF4560\"; // rouge\n\n            this.chart.updateOptions({\n                series: [this.currentTemp],\n                colors: [color]\n            });\n\n        },\n\n        initChart(){\n\n            const options = {\n\n                chart:{\n                    type:\"radialBar\",\n                    height:260,\n                    animations:{\n                        enabled:true,\n                        easing:\"easeinout\",\n                        speed:700\n                    }\n                },\n\n                series:[0],\n\n                labels:[\"Température\"],\n\n                colors:[\"#00E396\"],\n\n                plotOptions:{\n                    radialBar:{\n                        startAngle:-135,\n                        endAngle:135,\n\n                        hollow:{\n                            size:\"65%\"\n                        },\n\n                        track:{\n                            background:\"#1e1e1e\",\n                            strokeWidth:\"100%\"\n                        },\n\n                        dataLabels:{\n                            name:{\n                                color:\"#888\",\n                                fontSize:\"13px\",\n                                offsetY:-10\n                            },\n\n                            value:{\n                                color:\"#fff\",\n                                fontSize:\"26px\",\n                                offsetY:10,\n                                formatter:(val)=>{\n                                    return val.toFixed(1)+\" °C\"\n                                }\n                            }\n                        }\n                    }\n                },\n\n                stroke:{\n                    lineCap:\"round\"\n                }\n\n            };\n\n            const container = this.$el.querySelector(\".gauge\");\n\n            this.chart = new ApexCharts(container, options);\n\n            this.chart.render();\n\n        }\n\n    },\n\n    mounted(){\n\n        if(!window.ApexCharts){\n\n            const script = document.createElement(\"script\");\n\n            script.src = \"https://cdn.jsdelivr.net/npm/apexcharts\";\n\n            script.onload = () => this.initChart();\n\n            document.head.appendChild(script);\n\n        } else {\n\n            this.initChart();\n\n        }\n\n    },\n\n    unmounted(){\n\n        if(this.chart){\n            this.chart.destroy();\n        }\n\n    }\n}\n</script>\n\n<style>\n  .gauge-card {\n    background: #151515;\n    border-radius: 12px;\n    padding: 15px;\n    text-align: center;\n    border: 1px solid #222;\n  }\n\n  .card-title {\n    color: #00E396;\n    font-weight: bold;\n    text-transform: uppercase;\n    font-size: 0.8rem;\n    letter-spacing: 1px;\n  }\n\n  .gauge-container {\n    height: 260px;\n  }\n\n  .status-box {\n    margin-top: -25px;\n    font-size: 0.8rem;\n    color: #00E396;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n  }\n\n  .status-dot {\n    width: 8px;\n    height: 8px;\n    background: #00E396;\n    border-radius: 50%;\n  }\n\n  .alert {\n    color: #FF4560 !important;\n  }\n\n  .alert .status-dot {\n    background: #FF4560 !important;\n    box-shadow: 0 0 8px #FF4560;\n  }\n</style>",
